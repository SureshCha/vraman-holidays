1d:[["$","title","0",{"children":"𝐕𝐫𝐚𝐦𝐚𝐧 𝐇𝐨𝐥𝐢𝐝𝐚𝐲𝐬 "}],["$","meta","1",{"name":"description","content":"Vraman Holidays™ is a Nepal-based destination management company dedicated to helping travellers experience Nepal and the world in meaningful ways. We do not simply arrange trips – we create stories worth living, memories worth sharing, and experiences worth remembering. Every itinerary, every adventure, and every journey is designed with one purpose: to help our guests confidently Propose Your Destination™ while we take care of the rest."}],["$","link","2",{"rel":"icon","href":"/favicon.ico?favicon.2vob68tjqpejf.ico","sizes":"256x256","type":"image/x-icon"}],["$","link","3",{"rel":"icon","href":"https://res.cloudinary.com/dwnin5hyu/image/upload/v1783076376/vraman-holidays/jmrt798i9xgry1vtr15v.png"}],["$","$L23","4",{}]]
