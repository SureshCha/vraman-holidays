1c:["$","$L19",null,{"bio":"“Connecting Nepal to the world, one story at a time.” Prabidha Regmi plays a key role in shaping the global brand identity of Vraman Holidays™. Since the company's early days, she has contributed to international marketing, destination promotion, and brand positioning across multiple tourism platforms. Her focus on storytelling and authentic promotion continues to support the company's philosophy of creating compelling travel experiences rather than simply selling packages."}]
1d:["$","div","cmqpjfa9p000pkkt2sxvx468e",{"className":"text-center space-y-3 group","children":[["$","$L18",null,{"src":"https://res.cloudinary.com/dwnin5hyu/image/upload/v1782152857/vraman-holidays/u04bjq1gxlxvojaarcaj.jpg","alt":"Renu Kandel","width":120,"height":120,"className":"h-28 w-28 rounded-full object-cover mx-auto ring-4 ring-primary/10 group-hover:ring-primary/30 transition-all"}],["$","div",null,{"children":[["$","p",null,{"className":"font-semibold","children":"Renu Kandel"}],["$","p",null,{"className":"text-xs text-muted-foreground","children":"Marketing & Communications Manager"}]]}],["$","$L19",null,{"bio":"“Crafting messages that inspire meaningful travel.” Renu Kandel is responsible for marketing coordination, content communication, and promotional support at Vraman Holidays™. She works closely with the marketing team to develop engaging travel content, strengthen the company's digital presence, and enhance communication with clients and partners. Her creative approach and collaborative mindset help the brand connect with travellers in a meaningful and memorable way."}]]}]
1e:["$","div","cmqpjfae9000qkkt20ifpxfrd",{"className":"text-center space-y-3 group","children":[["$","$L18",null,{"src":"https://res.cloudinary.com/dwnin5hyu/image/upload/v1782152884/vraman-holidays/zfiedjbwk2ymt5w4rq5j.jpg","alt":"Nirmala Lamsal","width":120,"height":120,"className":"h-28 w-28 rounded-full object-cover mx-auto ring-4 ring-primary/10 group-hover:ring-primary/30 transition-all"}],["$","div",null,{"children":[["$","p",null,{"className":"font-semibold","children":"Nirmala Lamsal"}],["$","p",null,{"className":"text-xs text-muted-foreground","children":"Chief Operating Officer (COO)"}]]}],["$","$L19",null,{"bio":"“Turning purpose into action and values into impact.” Nirmala Lamsal oversees operational excellence, service quality, and organisational development at Vraman Holidays™. She believes successful tourism is built on trust, value creation, and genuine care for both guests and team members. A passionate advocate of responsible business, she champions the company's social impact initiatives through what she fondly calls the “Impact Fund”, believing meaningful growth is achieved when commercial success and social progress move forward together."}]]}]
1f:["$","div","cmqpjfaiv000rkkt227pjnhzc",{"className":"text-center space-y-3 group","children":[["$","$L18",null,{"src":"https://res.cloudinary.com/dwnin5hyu/image/upload/v1782152906/vraman-holidays/tv7brrjgblb9iygmtqus.jpg","alt":"Amrit Adhikari","width":120,"height":120,"className":"h-28 w-28 rounded-full object-cover mx-auto ring-4 ring-primary/10 group-hover:ring-primary/30 transition-all"}],["$","div",null,{"children":[["$","p",null,{"className":"font-semibold","children":"Amrit Adhikari"}],["$","p",null,{"className":"text-xs text-muted-foreground","children":"Director – Corporate Relations & Business Development"}]]}],["$","$L19",null,{"bio":"“Building partnerships that create opportunities.” Amrit Adhikari leads corporate relations and business development initiatives for Vraman Holidays™. With strong networking skills and a relationship-driven approach, he works closely with corporate clients, institutions, and business partners to create long-term collaborations. His focus on strategic growth and client satisfaction has helped expand the company's corporate travel and partnership portfolio."}]]}]
20:["$","div","cmqpjfana000skkt2tvveg7gv",{"className":"text-center space-y-3 group","children":[["$","$L18",null,{"src":"https://res.cloudinary.com/dwnin5hyu/image/upload/v1782153021/vraman-holidays/tzesebaqojuo4qjnch5r.jpg","alt":"Sulav Jung Hamal","width":120,"height":120,"className":"h-28 w-28 rounded-full object-cover mx-auto ring-4 ring-primary/10 group-hover:ring-primary/30 transition-all"}],["$","div",null,{"children":[["$","p",null,{"className":"font-semibold","children":"Sulav Jung Hamal"}],["$","p",null,{"className":"text-xs text-muted-foreground","children":"Director – North America Partnerships"}]]}],["$","$L19",null,{"bio":"“Creating bridges between people, destinations, and possibilities.” Sulav Jung Hamal is responsible for strengthening Vraman Holidays' partnership network across the United States and Canada. He works on building strategic alliances, identifying market opportunities, and developing relationships that support the company's international growth in North America."}]]}]
21:["$","div","cmqpjfas5000tkkt200iilkan",{"className":"text-center space-y-3 group","children":[["$","$L18",null,{"src":"https://res.cloudinary.com/dwnin5hyu/image/upload/v1782152990/vraman-holidays/npyjlomb4nujbbzdhaq2.jpg","alt":"Sushav Hamal","width":120,"height":120,"className":"h-28 w-28 rounded-full object-cover mx-auto ring-4 ring-primary/10 group-hover:ring-primary/30 transition-all"}],["$","div",null,{"children":[["$","p",null,{"className":"font-semibold","children":"Sushav Hamal"}],["$","p",null,{"className":"text-xs text-muted-foreground","children":"Manager – Strategic Alliances & Market Development"}]]}],["$","$L19",null,{"bio":"“Strong relationships create extraordinary outcomes.” Sushav Hamal focuses on strategic partnerships, market development, and international collaboration. Working closely with travel partners and business networks, she strengthens the company's global connections and identifies new opportunities for growth. Her forward-thinking approach contributes to partnerships that are both productive and sustainable."}]]}]
22:["$","div","cmqpjfawi000ukkt27p4fyss1",{"className":"text-center space-y-3 group","children":[["$","$L18",null,{"src":"https://res.cloudinary.com/dwnin5hyu/image/upload/v1782152961/vraman-holidays/oplkfno0hbrt5vq2utjd.jpg","alt":"Prasiddha Kandel","width":120,"height":120,"className":"h-28 w-28 rounded-full object-cover mx-auto ring-4 ring-primary/10 group-hover:ring-primary/30 transition-all"}],["$","div",null,{"children":[["$","p",null,{"className":"font-semibold","children":"Prasiddha Kandel"}],["$","p",null,{"className":"text-xs text-muted-foreground","children":"Manager – International Business Relations"}]]}],["$","$L19",null,{"bio":"“Expanding horizons through trusted partnerships.” Prasiddha Kandel supports Vraman Holidays' international business development through relationship management, market research, and strategic collaboration. He works with travel partners and clients to identify opportunities that enhance the company's global reach, with a focus on long-term value."}]]}]
23:["$","div","cmqpjfb1c000vkkt2nzqr0kpd",{"className":"text-center space-y-3 group","children":[["$","div",null,{"className":"h-28 w-28 rounded-full bg-gradient-to-br from-primary to-accent flex items-center justify-center mx-auto text-3xl font-bold text-white ring-4 ring-primary/10","children":"K"}],["$","div",null,{"children":[["$","p",null,{"className":"font-semibold","children":"Kami R Sherpa"}],["$","p",null,{"className":"text-xs text-muted-foreground","children":"Director – Tours & Guest Experience"}]]}],["$","$L19",null,{"bio":"“The best journeys are measured by smiles, not miles.” Kami R Sherpa has been with Vraman Holidays™ since its inception and is one of the company's most experienced tourism professionals. Beginning his career as a guide in Kathmandu's tourism sector, he has grown into a leader responsible for delivering safe, smooth, and memorable travel experiences across Nepal. His deep destination knowledge and genuine passion for hospitality make him an invaluable part of the family."}]]}]
24:["$","div","cmqpjfb5z000wkkt2w7275ak9",{"className":"text-center space-y-3 group","children":[["$","$L18",null,{"src":"https://res.cloudinary.com/dwnin5hyu/image/upload/v1782152927/vraman-holidays/c03amuvnf68l14fwpaap.jpg","alt":"Neestha Adhikari","width":120,"height":120,"className":"h-28 w-28 rounded-full object-cover mx-auto ring-4 ring-primary/10 group-hover:ring-primary/30 transition-all"}],["$","div",null,{"children":[["$","p",null,{"className":"font-semibold","children":"Neestha Adhikari"}],["$","p",null,{"className":"text-xs text-muted-foreground","children":"Manager – Reservations & Customer Success"}]]}],["$","$L19",null,{"bio":"“Every detail matters. Every traveller counts.” Neestha Adhikari manages reservations, client communications, and travel coordination for both individual travellers and business partners. She specialises in flights, accommodations, customised itineraries, and travel support services. Known for her attention to detail and problem-solving ability, she ensures every booking process is efficient, accurate, and stress-free."}]]}]
25:["$","div","cmqpjfbag000xkkt2h6roa67t",{"className":"text-center space-y-3 group","children":[["$","div",null,{"className":"h-28 w-28 rounded-full bg-gradient-to-br from-primary to-accent flex items-center justify-center mx-auto text-3xl font-bold text-white ring-4 ring-primary/10","children":"B"}],["$","div",null,{"children":[["$","p",null,{"className":"font-semibold","children":"Bishnu Ma'am"}],["$","p",null,{"className":"text-xs text-muted-foreground","children":"Workplace & Guest Hospitality Coordinator"}]]}],["$","$L19",null,{"bio":"“Hospitality begins with making people feel at home.” Bishnu Ma'am helps create the welcoming environment that guests and team members experience every day at Vraman Holidays™. She supports office operations, guest hospitality, and workplace coordination, ensuring the office remains organised, comfortable, and inviting. Her caring nature, reliability, and dedication contribute greatly to the positive culture that defines the family."}]]}]
