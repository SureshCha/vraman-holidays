40:["$","div","cmqpjfa57000okkt2nax91xfr",{"className":"text-center space-y-3 group","children":[["$","$L3e",null,{"src":"https://res.cloudinary.com/dwnin5hyu/image/upload/v1782152826/vraman-holidays/kbopsihpwkmutiar10sx.jpg","alt":"Prabidha Regmi","width":120,"height":120,"className":"h-28 w-28 rounded-full object-cover mx-auto ring-4 ring-primary/10 group-hover:ring-primary/30 transition-all"}],["$","div",null,{"children":[["$","p",null,{"className":"font-semibold","children":"Prabidha Regmi"}],["$","p",null,{"className":"text-xs text-muted-foreground","children":"Director – Global Brand & Marketing"}]]}],["$","$L3f",null,{"bio":"“Connecting Nepal to the world, one story at a time.” Prabidha Regmi plays a key role in shaping the global brand identity of Vraman Holidays™. Since the company's early days, she has contributed to international marketing, destination promotion, and brand positioning across multiple tourism platforms. Her focus on storytelling and authentic promotion continues to support the company's philosophy of creating compelling travel experiences rather than simply selling packages."}]]}]
41:["$","div","cmqpjfa9p000pkkt2sxvx468e",{"className":"text-center space-y-3 group","children":[["$","$L3e",null,{"src":"https://res.cloudinary.com/dwnin5hyu/image/upload/v1782152857/vraman-holidays/u04bjq1gxlxvojaarcaj.jpg","alt":"Renu Kandel","width":120,"height":120,"className":"h-28 w-28 rounded-full object-cover mx-auto ring-4 ring-primary/10 group-hover:ring-primary/30 transition-all"}],["$","div",null,{"children":[["$","p",null,{"className":"font-semibold","children":"Renu Kandel"}],["$","p",null,{"className":"text-xs text-muted-foreground","children":"Marketing & Communications Manager"}]]}],["$","$L3f",null,{"bio":"“Crafting messages that inspire meaningful travel.” Renu Kandel is responsible for marketing coordination, content communication, and promotional support at Vraman Holidays™. She works closely with the marketing team to develop engaging travel content, strengthen the company's digital presence, and enhance communication with clients and partners. Her creative approach and collaborative mindset help the brand connect with travellers in a meaningful and memorable way."}]]}]
42:["$","div","cmqpjfae9000qkkt20ifpxfrd",{"className":"text-center space-y-3 group","children":[["$","$L3e",null,{"src":"https://res.cloudinary.com/dwnin5hyu/image/upload/v1782152884/vraman-holidays/zfiedjbwk2ymt5w4rq5j.jpg","alt":"Nirmala Lamsal","width":120,"height":120,"className":"h-28 w-28 rounded-full object-cover mx-auto ring-4 ring-primary/10 group-hover:ring-primary/30 transition-all"}],["$","div",null,{"children":[["$","p",null,{"className":"font-semibold","children":"Nirmala Lamsal"}],["$","p",null,{"className":"text-xs text-muted-foreground","children":"Chief Operating Officer (COO)"}]]}],["$","$L3f",null,{"bio":"“Turning purpose into action and values into impact.” Nirmala Lamsal oversees operational excellence, service quality, and organisational development at Vraman Holidays™. She believes successful tourism is built on trust, value creation, and genuine care for both guests and team members. A passionate advocate of responsible business, she champions the company's social impact initiatives through what she fondly calls the “Impact Fund”, believing meaningful growth is achieved when commercial success and social progress move forward together."}]]}]
43:["$","div","cmqpjfaiv000rkkt227pjnhzc",{"className":"text-center space-y-3 group","children":[["$","$L3e",null,{"src":"https://res.cloudinary.com/dwnin5hyu/image/upload/v1783075689/vraman-holidays/mfwkzewp8exeaqvuf7rh.jpg","alt":"Amrit Adhikari","width":120,"height":120,"className":"h-28 w-28 rounded-full object-cover mx-auto ring-4 ring-primary/10 group-hover:ring-primary/30 transition-all"}],["$","div",null,{"children":[["$","p",null,{"className":"font-semibold","children":"Amrit Adhikari"}],["$","p",null,{"className":"text-xs text-muted-foreground","children":"Director – Corporate Relations & Business Development"}]]}],["$","$L3f",null,{"bio":"“Building partnerships that create opportunities.” Amrit Adhikari leads corporate relations and business development initiatives for Vraman Holidays™. With strong networking skills and a relationship-driven approach, he works closely with corporate clients, institutions, and business partners to create long-term collaborations. His focus on strategic growth and client satisfaction has helped expand the company's corporate travel and partnership portfolio."}]]}]
