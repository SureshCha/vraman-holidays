// Vraman Holidays — Prisma Schema
// Single source of truth for all data models.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  OWNER
  ADMIN
  EDITOR
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum PaymentGateway {
  ESEWA
  KHALTI
  STRIPE
  BANK_TRANSFER
}

enum EnquiryType {
  CONTACT
  PROPOSE
}

enum SectionType {
  HERO
  SEARCH
  FEATURED_PACKAGES
  DESTINATIONS
  TESTIMONIALS
  BLOG_PREVIEW
  RICH_TEXT
  GALLERY
  CTA
  STATS
  CONTACT_FORM
  PAGE_HEADER
  FEATURE_GRID
  CHECKLIST
  CREDENTIALS
  IMAGE_BAND
}

// ─── Auth Models (Auth.js / NextAuth v5) ─────────────────────────────────────

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  name          String?
  passwordHash  String
  role          Role          @default(EDITOR)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  accounts      Account[]
  sessions      Session[]
  blogPosts     BlogPost[]
  mediaAssets   MediaAsset[]
  auditLogs     AuditLog[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Site Configuration ───────────────────────────────────────────────────────

/// Singleton row (id = 1). All global site config lives here.
model SiteSettings {
  id             Int      @id @default(1)
  /// { name, tagline, logoUrl, faviconUrl }
  brand          Json
  /// { primaryColor, secondaryColor, accentColor, fontFamily, borderRadius }
  theme          Json
  /// { phone, email, address, officeHours, mapEmbed, whatsappNumber }
  contact        Json
  /// { facebook, instagram, youtube, tiktok, twitter }
  social         Json
  /// { enableBlog, enableTestimonials, enableWhatsapp, enableEsewa, enableKhalti, enableStripe, enableBankTransfer }
  featureFlags   Json
  /// { titleTemplate, defaultDescription, defaultOgImage }
  seoDefaults    Json
  /// { fromEmail, replyTo, bookingSubject, enquirySubject, footerText }
  emailTemplates Json
  /// { bankName, accountName, accountNumber, ifscOrSwift, instructions }
  paymentConfig  Json
  /// { imageUrl?, videoUrl?, posterUrl? } — optional footer background media
  footer         Json     @default("{}")
  updatedAt      DateTime @updatedAt
}

model Navigation {
  id        String       @id @default(cuid())
  /// "header" | "footer"
  location  String
  label     String
  href      String
  order     Int          @default(0)
  openInNew Boolean      @default(false)
  parentId  String?
  parent    Navigation?  @relation("NavTree", fields: [parentId], references: [id])
  children  Navigation[] @relation("NavTree")
  @@index([parentId])
  @@index([location])
}

// ─── Content: Destinations & Packages ────────────────────────────────────────

model Destination {
  id          String        @id @default(cuid())
  slug        String        @unique
  name        String
  country     String
  /// Short brand-identity line, e.g. "The Gateway to Sacred Nepal"
  tagline     String?
  /// "NEPAL" (Discover Nepal / inbound) or "WORLD" (Discover the World / outbound)
  region      String        @default("WORLD")
  description String?       @db.Text
  imageUrl    String?
  order       Int           @default(0)
  status      ContentStatus @default(DRAFT)
  packages    Package[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model TripType {
  id       String    @id @default(cuid())
  slug     String    @unique
  name     String
  order    Int       @default(0)
  packages Package[]
}

model Package {
  id              String             @id @default(cuid())
  slug            String             @unique
  title           String
  subtitle        String?
  destinationId   String
  destination     Destination        @relation(fields: [destinationId], references: [id])
  tripTypes       TripType[]
  durationDays    Int
  durationNights  Int
  priceFrom       Int                // minor units (paisa for NPR)
  currency        String             @default("NPR")
  /// Origin city, e.g. "Kathmandu" (round-trip)
  departureCity   String?
  /// Sharing/basis info, e.g. "Per person, double/twin sharing"
  priceBasis      String?
  /// Minimum group size for the quoted price
  minGroupSize    Int?
  /// Pricing validity end date
  validUntil      DateTime?
  description     String?            @db.Text
  /// String[] — highlight bullet points
  highlights      Json               @default("[]")
  /// String[] — what is included
  inclusions      Json               @default("[]")
  /// String[] — what is excluded
  exclusions      Json               @default("[]")
  /// String[] — Cloudinary URLs
  galleryImages   Json               @default("[]")
  coverImage      String?
  status          ContentStatus      @default(DRAFT)
  featured        Boolean            @default(false)
  metaTitle       String?
  metaDescription String?
  /// Package-specific terms & conditions (rich text)
  terms           String?            @db.Text
  itinerary       ItineraryDay[]
  departures      PackageDeparture[]
  bookings        Booking[]
  testimonials    Testimonial[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  @@index([destinationId])
  @@index([status])
}

model ItineraryDay {
  id            String   @id @default(cuid())
  packageId     String
  package       Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)
  dayNumber     Int
  title         String
  /// Day catchline, e.g. "A Vibrant Seaside Escape"
  subtitle      String?
  /// Condensed route, e.g. "Airport → Van → Alcazar Show"
  summaryStrip  String?
  description   String   @db.Text
  /// { breakfast: boolean, lunch: boolean, dinner: boolean }
  meals         Json?
  accommodation String?
  imageUrl      String?
  /// String[] — multiple Cloudinary URLs per day
  images        Json     @default("[]")
  /// Warning/alert note, e.g. "Safari World closed every Monday"
  alert         String?
  /// GPS coordinates for the route map (optional per day)
  latitude      Float?
  longitude     Float?
  /// Elevation in meters above sea level
  elevation     Int?
  @@index([packageId])
}

model PackageDeparture {
  id            String    @id @default(cuid())
  packageId     String
  package       Package   @relation(fields: [packageId], references: [id], onDelete: Cascade)
  departureDate DateTime
  returnDate    DateTime
  maxSeats      Int
  bookedSeats   Int       @default(0)
  /// If null, use Package.priceFrom
  priceOverride Int?
  currency      String    @default("NPR")
  bookings      Booking[]
  @@index([packageId])
}

// ─── Bookings & Payments ──────────────────────────────────────────────────────

model Booking {
  id          String             @id @default(cuid())
  bookingRef  String             @unique @default(cuid())
  packageId   String
  package     Package            @relation(fields: [packageId], references: [id])
  departureId String?
  departure   PackageDeparture?  @relation(fields: [departureId], references: [id])
  status      BookingStatus      @default(PENDING)
  totalAmount Int
  currency    String             @default("NPR")
  /// Applied promo code id (if any) and the discount it produced, in minor units.
  promoCodeId    String?
  discountAmount Int             @default(0)
  notes              String?            @db.Text
  travelInsurance    Boolean            @default(false)
  travellers         Traveller[]
  payments    PaymentTransaction[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  @@index([packageId])
  @@index([departureId])
  @@index([status])
  @@index([createdAt])
}

model Traveller {
  id          String    @id @default(cuid())
  bookingId   String
  booking     Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  firstName   String
  lastName    String
  email       String
  phone       String
  nationality String?
  passportNo      String?
  dob             DateTime?
  address         String?
  specialRequests String?    @db.Text
  isPrimary       Boolean   @default(false)
  @@index([bookingId])
}

model PaymentTransaction {
  id           String         @id @default(cuid())
  bookingId    String
  booking      Booking        @relation(fields: [bookingId], references: [id])
  gateway      PaymentGateway
  gatewayTxnId String?
  amount       Int
  currency     String         @default("NPR")
  status       PaymentStatus  @default(PENDING)
  /// Full gateway response for audit trail
  rawResponse  Json?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  /// Idempotency: a retried webhook for the same (gateway, txn, outcome) upserts
  /// instead of inserting a duplicate. Composite (not txn-only) so a fail-then-
  /// succeed on the same gateway intent can still record both outcomes. Nullable
  /// gatewayTxnId keeps multiple NULL-txn rows valid (Postgres NULLs are distinct).
  @@unique([gateway, gatewayTxnId, status])
  @@index([bookingId])
  @@index([status])
}

// ─── Blog ──────────────────────────────────────────────────────────────────────

model BlogPost {
  id              String        @id @default(cuid())
  slug            String        @unique
  title           String
  excerpt         String?
  content         String        @db.Text
  coverImage      String?
  authorId        String?
  author          User?         @relation(fields: [authorId], references: [id])
  status          ContentStatus @default(DRAFT)
  publishedAt     DateTime?
  metaTitle       String?
  metaDescription String?
  /// String[] — blog tags
  tags            Json          @default("[]")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  @@index([authorId])
  @@index([status])
}

// ─── Testimonials ──────────────────────────────────────────────────────────────

model Testimonial {
  id        String        @id @default(cuid())
  name      String
  location  String?
  packageId String?
  package   Package?      @relation(fields: [packageId], references: [id])
  rating    Int           // 1–5
  content   String        @db.Text
  imageUrl  String?
  status    ContentStatus @default(DRAFT)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  @@index([packageId])
  @@index([status])
}

// ─── Enquiries ─────────────────────────────────────────────────────────────────

model Enquiry {
  id             String      @id @default(cuid())
  type           EnquiryType
  name           String
  email          String
  phone          String?
  message        String      @db.Text
  // Propose-specific
  destination    String?
  travelDates    String?
  groupSize      Int?
  budget         Int?
  budgetCurrency String?
  read           Boolean     @default(false)
  createdAt      DateTime    @default(now())
}

// ─── CMS: Pages & Sections ────────────────────────────────────────────────────

model Page {
  id              String        @id @default(cuid())
  slug            String        @unique
  title           String
  status          ContentStatus @default(DRAFT)
  metaTitle       String?
  metaDescription String?
  sections        PageSection[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model PageSection {
  id      String      @id @default(cuid())
  pageId  String
  page    Page        @relation(fields: [pageId], references: [id], onDelete: Cascade)
  type    SectionType
  order   Int
  /// Section-specific payload, structure depends on type
  data    Json
  visible Boolean     @default(true)
  @@index([pageId])
}

model HomeSection {
  id      String      @id @default(cuid())
  type    SectionType
  order   Int
  /// Section-specific payload
  data    Json
  visible Boolean     @default(true)
}

model LegalPage {
  id        String   @id @default(cuid())
  slug      String   @unique // "terms" | "privacy" | "refund"
  title     String
  content   String   @db.Text
  updatedAt DateTime @updatedAt
}

// ─── Media ─────────────────────────────────────────────────────────────────────

model MediaAsset {
  id           String   @id @default(cuid())
  publicId     String   @unique // Cloudinary public_id
  url          String
  resourceType String?  @default("image") // Cloudinary resource_type: "image" | "video"
  format       String?
  width        Int?
  height       Int?
  bytes        Int?
  duration     Float?   // video length in seconds (null for images)
  folder       String?
  /// String[] — Cloudinary tags
  tags         Json     @default("[]")
  uploadedById String?
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())
  @@index([uploadedById])
}

// ─── Promo Codes ───────────────────────────────────────────────────────────────

model PromoCode {
  id              String        @id @default(cuid())
  code            String        @unique
  /// Percentage discount (e.g. 10 = 10% off). Mutually exclusive with discountFixed.
  discountPercent Int?
  /// Fixed amount discount in minor units. Mutually exclusive with discountPercent.
  discountFixed   Int?
  currency        String        @default("NPR")
  validFrom       DateTime
  validUntil      DateTime
  maxUses         Int?
  usedCount       Int           @default(0)
  status          ContentStatus @default(DRAFT)
  createdAt       DateTime      @default(now())
}

// ─── Newsletter ────────────────────────────────────────────────────────────────

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

// ─── FAQ ───────────────────────────────────────────────────────────────────────

model Faq {
  id       String  @id @default(cuid())
  question String
  answer   String  @db.Text
  category String  @default("General")
  order    Int     @default(0)
  visible  Boolean @default(true)
}

// ─── Team Members ──────────────────────────────────────────────────────────────

model TeamMember {
  id       String  @id @default(cuid())
  name     String
  role     String
  bio      String? @db.Text
  imageUrl String?
  order    Int     @default(0)
  visible  Boolean @default(true)
}

// ─── Audit Log ─────────────────────────────────────────────────────────────────

model PromoPopup {
  id        String    @id @default(cuid())
  title     String
  imageUrl  String
  linkUrl   String
  alt       String    @default("")
  visible   Boolean   @default(true)
  startDate DateTime?
  endDate   DateTime?
  order     Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([visible, startDate, endDate])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String   // e.g. "booking.status_change", "settings.update"
  entity    String   // e.g. "Booking", "SiteSettings"
  entityId  String?
  details   Json?
  createdAt DateTime @default(now())
  @@index([userId])
  @@index([createdAt])
}
