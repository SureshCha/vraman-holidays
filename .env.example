# ─────────────────────────────────────────────────────────────────────────────
# Vraman Holidays — environment variables
#
# Copy to `.env` for local dev. NEVER commit real values.
# Where each environment's real values live:
#   • Local dev   → your local .env (gitignored)
#   • Vercel (dev)→ Vercel Project → Settings → Environment Variables
#   • Babal (prod)→ cPanel → Setup Node.js App → (this app) → environment vars
#   • CI build    → GitHub repo → Settings → Secrets and variables → Actions
#
# The matrix in DEPLOYMENT.md says exactly which value goes where.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (PostgreSQL on Neon) ────────────────────────────────────────────
# Use a SEPARATE Neon branch per environment so test data never reaches prod:
#   • Vercel (dev) → Neon "dev" branch connection string
#   • Babal (prod) → Neon "production" branch connection string
#   • CI build     → the prod string (build runs generateStaticParams against it)
# Append &connect_timeout=15 for resilience on cold Neon branches.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require&connect_timeout=15"

# ── Auth (NextAuth / Auth.js v5) ─────────────────────────────────────────────
# AUTH_SECRET is the v5 name (NEXTAUTH_SECRET still works as a fallback).
# Generate: openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"   # set to the same value
# Public URL of the running site (dev = Vercel URL, prod = the live domain).
NEXTAUTH_URL="http://localhost:3000"      # prod: https://vramanholidays.com.np
AUTH_URL="http://localhost:3000"          # prod: https://vramanholidays.com.np
AUTH_TRUST_HOST="true"                    # required behind Vercel / cPanel proxy

# ── Public site URL (sitemap, robots, payment callbacks, emails) ─────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"   # prod: https://vramanholidays.com.np

# ── Payments ─────────────────────────────────────────────────────────────────
# PAYMENTS_MODE: "sandbox" on dev/Vercel, "production" on Babal once tested.
PAYMENTS_MODE="sandbox"
ESEWA_MERCHANT_CODE=""
ESEWA_SECRET=""
KHALTI_SECRET_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
# Production webhook endpoint: https://vramanholidays.com.np/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=""

# ── Email ─────────────────────────────────────────────────────────────────────
# The app sends transactional email through ONE transport, chosen automatically:
#   1. SMTP (cPanel mailbox) — used when SMTP_HOST/USER/PASS are all set
#   2. Resend — used if SMTP isn't set but RESEND_API_KEY is
#   3. none — emails are skipped gracefully (no crash)
#
# Option A — cPanel SMTP (Babal mailbox):
SMTP_HOST="mail.vramanholidays.com.np"   # before DNS propagates: phillips.mysecurecloudserver.com
SMTP_PORT="465"                          # 465 = SSL, 587 = STARTTLS
SMTP_USER="info@vramanholidays.com.np"   # the full mailbox address
SMTP_PASS=""                             # the mailbox password
SMTP_FROM="info@vramanholidays.com.np"   # optional; defaults to SMTP_USER
# Also set the brand "From" address in Admin → Settings → email to this mailbox.
#
# Option B — Resend (leave SMTP_* blank to use this):
RESEND_API_KEY=""

# ── Cloudinary (media) ────────────────────────────────────────────────────────
# CLOUDINARY_CLOUD_NAME is also needed at BUILD time (next.config derives
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME from it).
CLOUDINARY_URL="cloudinary://API_KEY:API_SECRET@CLOUD_NAME"
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ── Analytics ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=""
